{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": ["ESNext"],
    "types": ["bun"],
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "fixture-pack.json"]
}
